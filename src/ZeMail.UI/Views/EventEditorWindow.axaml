<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZeMail.UI.ViewModels"
        x:Class="ZeMail.UI.Views.EventEditorWindow"
        x:DataType="vm:EventEditorViewModel"
        Title="{Binding WindowTitle}"
        Icon="/Assets/zemail.ico"
        Width="500" Height="580"
        MinWidth="420" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#0f0f23">

    <Window.Styles>
        <Style Selector="Button.DateBtn">
            <Setter Property="Background"                  Value="#1a1a3a"/>
            <Setter Property="BorderBrush"                 Value="#2a2a5a"/>
            <Setter Property="BorderThickness"             Value="1"/>
            <Setter Property="CornerRadius"                Value="6"/>
            <Setter Property="Padding"                     Value="10,7"/>
            <Setter Property="Foreground"                  Value="#c0c0ff"/>
            <Setter Property="FontSize"                    Value="13"/>
            <Setter Property="HorizontalContentAlignment"  Value="Left"/>
            <Setter Property="HorizontalAlignment"         Value="Stretch"/>
        </Style>
        <Style Selector="Button.DateBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22224a"/>
        </Style>
        <Style Selector="Button.CalDay">
            <Setter Property="Width"                      Value="30"/>
            <Setter Property="Height"                     Value="30"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="CornerRadius"               Value="15"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="FontSize"                   Value="12"/>
            <Setter Property="Foreground"                 Value="#c0c0e0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
        </Style>
        <Style Selector="Button.CalDay:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2a2a5a"/>
        </Style>
        <Style Selector="Button.CalDaySelected">
            <Setter Property="Width"                      Value="30"/>
            <Setter Property="Height"                     Value="30"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="CornerRadius"               Value="15"/>
            <Setter Property="Background"                 Value="#3a3aff"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="FontSize"                   Value="12"/>
            <Setter Property="FontWeight"                 Value="Bold"/>
            <Setter Property="Foreground"                 Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
        </Style>
        <Style Selector="Button.CalDayToday">
            <Setter Property="Width"                      Value="30"/>
            <Setter Property="Height"                     Value="30"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="CornerRadius"               Value="15"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderBrush"                Value="#3a3aff"/>
            <Setter Property="BorderThickness"            Value="1"/>
            <Setter Property="FontSize"                   Value="12"/>
            <Setter Property="Foreground"                 Value="#8080ff"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
        </Style>
        <Style Selector="Button.CalDayOtherMonth">
            <Setter Property="Opacity" Value="0.3"/>
        </Style>
        <Style Selector="Button.CalNav">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="Foreground"      Value="#8080c0"/>
            <Setter Property="FontSize"        Value="16"/>
        </Style>
        <Style Selector="ComboBox.TimeCombo">
            <Setter Property="Width"           Value="100"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#c0c0ff"/>
            <Setter Property="Background"      Value="#1a1a3a"/>
            <Setter Property="BorderBrush"     Value="#2a2a5a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="8,0"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto" Margin="20">

        <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="14">

                <!-- Titel -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Titel *" Foreground="#8080a0" FontSize="12"/>
                    <TextBox Text="{Binding Title}"
                             PlaceholderText="Terminbezeichnung"
                             CornerRadius="6" Padding="10,6"/>
                </StackPanel>

                <!-- Kalender-Auswahl -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Kalender" Foreground="#8080a0" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding AvailableCalendars}"
                              SelectedItem="{Binding SelectedCalendar}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:CalendarPickerItem">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="10" Height="10"
                                             Fill="{Binding Color}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#c0c0ff" FontSize="13"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Ort -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Ort" Foreground="#8080a0" FontSize="12"/>
                    <TextBox Text="{Binding Location}"
                             PlaceholderText="optional"
                             CornerRadius="6" Padding="10,6"/>
                </StackPanel>

                <!-- Ganztägig -->
                <CheckBox Content="Ganztägiger Termin"
                          IsChecked="{Binding IsAllDay}"
                          Foreground="#c0c0e0"/>

                <!-- ══ START ══ -->
                <Grid ColumnDefinitions="*,12,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Startdatum" Foreground="#8080a0" FontSize="12"/>
                        <Panel>
                            <Button Content="{Binding StartDateLabel}"
                                    Command="{Binding ToggleStartCalendarCommand}"
                                    Classes="DateBtn"/>
                            <Popup IsOpen="{Binding StartCalendarOpen}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding $parent[Panel]}"
                                   IsLightDismissEnabled="True">
                                <Border Background="#12122a" BorderBrush="#2a2a5a"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="10" Width="230">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Button Grid.Column="0" Content="‹"
                                                    Command="{Binding StartCalendarPrevCommand}"
                                                    Classes="CalNav"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding StartCalendarTitle}"
                                                       Foreground="#c0c0ff" FontWeight="SemiBold"
                                                       FontSize="13" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Content="›"
                                                    Command="{Binding StartCalendarNextCommand}"
                                                    Classes="CalNav"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding StartWeekHeaders}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><UniformGrid Columns="7"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="#4040a0"
                                                               FontSize="11" TextAlignment="Center"
                                                               Width="30" Height="22" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl ItemsSource="{Binding StartCalendarDays}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><UniformGrid Columns="7"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:MiniCalendarDay">
                                                    <Button Content="{Binding Label}"
                                                            Command="{Binding $parent[Window].((vm:EventEditorViewModel)DataContext).SelectStartDayCommand}"
                                                            CommandParameter="{Binding}"
                                                            Classes.CalDaySelected="{Binding IsSelected}"
                                                            Classes.CalDayToday="{Binding IsToday}"
                                                            Classes.CalDay="{Binding !IsSelected}"
                                                            Classes.CalDayOtherMonth="{Binding !IsCurrentMonth}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Panel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4"
                                IsVisible="{Binding !IsAllDay}">
                        <TextBlock Text="Uhrzeit" Foreground="#8080a0" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding TimeSlots}"
                                  SelectedItem="{Binding SelectedStartTime}"
                                  Classes="TimeCombo"/>
                    </StackPanel>
                </Grid>

                <!-- ══ ENDE ══ -->
                <Grid ColumnDefinitions="*,12,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Enddatum" Foreground="#8080a0" FontSize="12"/>
                        <Panel>
                            <Button Content="{Binding EndDateLabel}"
                                    Command="{Binding ToggleEndCalendarCommand}"
                                    Classes="DateBtn"/>
                            <Popup IsOpen="{Binding EndCalendarOpen}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding $parent[Panel]}"
                                   IsLightDismissEnabled="True">
                                <Border Background="#12122a" BorderBrush="#2a2a5a"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="10" Width="230">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Button Grid.Column="0" Content="‹"
                                                    Command="{Binding EndCalendarPrevCommand}"
                                                    Classes="CalNav"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding EndCalendarTitle}"
                                                       Foreground="#c0c0ff" FontWeight="SemiBold"
                                                       FontSize="13" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Content="›"
                                                    Command="{Binding EndCalendarNextCommand}"
                                                    Classes="CalNav"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding EndWeekHeaders}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><UniformGrid Columns="7"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="#4040a0"
                                                               FontSize="11" TextAlignment="Center"
                                                               Width="30" Height="22" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl ItemsSource="{Binding EndCalendarDays}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><UniformGrid Columns="7"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:MiniCalendarDay">
                                                    <Button Content="{Binding Label}"
                                                            Command="{Binding $parent[Window].((vm:EventEditorViewModel)DataContext).SelectEndDayCommand}"
                                                            CommandParameter="{Binding}"
                                                            Classes.CalDaySelected="{Binding IsSelected}"
                                                            Classes.CalDayToday="{Binding IsToday}"
                                                            Classes.CalDay="{Binding !IsSelected}"
                                                            Classes.CalDayOtherMonth="{Binding !IsCurrentMonth}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Panel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4"
                                IsVisible="{Binding !IsAllDay}">
                        <TextBlock Text="Uhrzeit" Foreground="#8080a0" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding TimeSlots}"
                                  SelectedItem="{Binding SelectedEndTime}"
                                  Classes="TimeCombo"/>
                    </StackPanel>
                </Grid>

                <!-- Beschreibung -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Beschreibung" Foreground="#8080a0" FontSize="12"/>
                    <TextBox Text="{Binding Description}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="80"
                             CornerRadius="6" Padding="10,6"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,12,0,0">
            <Button Grid.Column="0"
                    Content="🗑 Löschen"
                    Command="{Binding DeleteCommand}"
                    IsVisible="{Binding IsEditMode}"
                    IsEnabled="{Binding !IsSaving}"
                    Background="#4a1a1a" Foreground="#ff6060"
                    CornerRadius="6" Padding="12,8"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding StatusMessage}"
                       Foreground="#a0a0ff" FontSize="12"
                       VerticalAlignment="Center" Margin="12,0"/>
            <Button Grid.Column="2"
                    Content="Abbrechen"
                    Command="{Binding CancelCommand}"
                    Background="Transparent" Foreground="#6060a0"
                    Padding="12,8" Margin="0,0,8,0"/>
            <Button Grid.Column="3"
                    Content="Speichern ✓"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding !IsSaving}"
                    Background="#3a3aff" Foreground="White"
                    FontWeight="SemiBold" CornerRadius="6"
                    Padding="16,8"/>
        </Grid>

    </Grid>
</Window>