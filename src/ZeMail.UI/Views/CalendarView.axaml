<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZeMail.UI.ViewModels"
             xmlns:m="using:ZeMail.UI.Models"
             x:Class="ZeMail.UI.Views.CalendarView"
             x:DataType="vm:CalendarViewModel">

    <Grid ColumnDefinitions="*,260" RowDefinitions="56,*">

        <!-- ── Topbar ── -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
                Background="#12122a"
                BorderThickness="0,0,0,1" BorderBrush="#2a2a4a"
                Padding="16,0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">

                <Button Grid.Column="0" Content="◀"
                        Command="{Binding PreviousMonthCommand}"
                        Background="Transparent" Foreground="#c0c0ff"
                        FontSize="16" Width="36" Height="36"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentMonthLabel}"
                           Foreground="#e0e0ff"
                           FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="8,0"/>

                <Button Grid.Column="2" Content="▶"
                        Command="{Binding NextMonthCommand}"
                        Background="Transparent" Foreground="#c0c0ff"
                        FontSize="16" Width="36" Height="36"/>

                <Button Grid.Column="3" Content="Heute"
                        Command="{Binding GoToTodayCommand}"
                        Background="Transparent" Foreground="#7070ff"
                        FontSize="13" HorizontalAlignment="Left"
                        Margin="16,0" Padding="8,4"/>

                <Button Grid.Column="4" Content="+ Neuer Termin"
                        Command="{Binding NewEventCommand}"
                        Background="#3a3aff" Foreground="White"
                        FontSize="13" FontWeight="SemiBold"
                        CornerRadius="6" Padding="12,6"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Monatsraster ── -->
        <Grid Grid.Column="0" Grid.Row="1" RowDefinitions="32,*">

            <!-- Wochentag-Header -->
            <ItemsControl Grid.Row="0" ItemsSource="{Binding WeekDayHeaders}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="0,0,1,1" BorderBrush="#1a1a3a"
                                Background="#0f0f20">
                            <TextBlock Text="{Binding}"
                                       Foreground="#6060a0"
                                       FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Tage-Raster -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Days}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="m:CalendarDayViewModel">
                        <Border BorderThickness="0,0,1,1"
                                BorderBrush="#1a1a3a"
                                Background="Transparent"
                                Cursor="Hand">
                            <Border.Styles>
                                <Style Selector="Border:pointerover">
                                    <Setter Property="Background" Value="#1a1a3a"/>
                                </Style>
                            </Border.Styles>
                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Padding="0"
                                    Command="{Binding $parent[UserControl].DataContext.SelectDayCommand}"
                                    CommandParameter="{Binding}">
                                <Grid RowDefinitions="24,*">

                                    <!-- Tageszahl -->
                                    <Panel Grid.Row="0" HorizontalAlignment="Right"
                                        Margin="4,4,4,0" Width="24" Height="24">
                                        <Ellipse Fill="#3a3aff"
                                                IsVisible="{Binding IsToday}"/>
                                        <TextBlock Text="{Binding DayNumber}"
                                                FontSize="12"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="#c0c0e0"/>
                                    </Panel>

                                    <!-- Events -->
                                    <ItemsControl Grid.Row="1"
                                                ItemsSource="{Binding Events}"
                                                Margin="2,0,2,2">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="m:CalendarEventViewModel">
                                                <Border Background="#3a3aff"
                                                        CornerRadius="3"
                                                        Padding="4,1"
                                                        Margin="0,1">
                                                    <TextBlock Text="{Binding DisplayTitle}"
                                                            Foreground="White"
                                                            FontSize="10"
                                                            TextTrimming="CharacterEllipsis"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </Grid>
                            </Button>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- ── Rechte Seitenleiste: Tagesdetail ── -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="#0a0a1a"
                BorderThickness="1,0,0,0" BorderBrush="#2a2a4a"
                Padding="16">
            <StackPanel Spacing="12">

                <TextBlock Text="{Binding SelectedDay.Date, StringFormat='{}{0:dddd, dd. MMMM}'}"
                           Foreground="#c0c0ff"
                           FontSize="14" FontWeight="SemiBold"/>

                <TextBlock Text="Keine Termine"
                           Foreground="#4040a0"
                           FontSize="12"
                           IsVisible="{Binding SelectedDayEvents.Count,
                                       Converter={x:Static ObjectConverters.IsNull}}"/>

                <ItemsControl ItemsSource="{Binding SelectedDayEvents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="m:CalendarEventViewModel">
                            <Border Background="#12122a"
                                    CornerRadius="8"
                                    Padding="12,8"
                                    Margin="0,0,0,8"
                                    BorderThickness="3,0,0,0"
                                    BorderBrush="#5AC8FA">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="#e0e0ff"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding StartTime}"
                                               Foreground="#7070ff"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding Location}"
                                               Foreground="#6060a0"
                                               FontSize="11"
                                               IsVisible="{Binding Location,
                                                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>