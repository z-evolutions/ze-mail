<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZeMail.UI.ViewModels"
             xmlns:m="using:ZeMail.UI.Models"
             x:Class="ZeMail.UI.Views.MailboxView"
             x:DataType="vm:MailboxViewModel">

    <Grid ColumnDefinitions="220,320,*">

        <!-- ── Spalte 1: Ordnerbaum ── -->
        <Border Grid.Column="0"
                Background="{DynamicResource ZeSurfaceBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource ZeBorderBrush}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="ORDNER"
                           Foreground="{DynamicResource ZeTextSecondaryBrush}"
                           FontSize="11" FontWeight="Bold"
                           Margin="12,16,12,8"/>
                <ListBox ItemsSource="{Binding Folders}"
                         SelectedItem="{Binding SelectedFolder}"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:FolderViewModel">
                            <Panel>
                                <TextBlock Text="{Binding AccountName}"
                                           IsVisible="{Binding IsAccountHeader}"
                                           Foreground="{DynamicResource ZeAccentBrush}"
                                           FontSize="10" FontWeight="Bold"
                                           Margin="8,12,4,2"/>
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            Margin="12,2,4,2"
                                            IsVisible="{Binding !IsAccountHeader}">
                                    <TextBlock Text="{Binding Icon}" FontSize="14"/>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{DynamicResource ZeTextPrimaryBrush}"
                                               FontSize="13"/>
                                </StackPanel>
                            </Panel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource ZeSelectedBrush}"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ── Spalte 2: Nachrichtenliste ── -->
        <Border Grid.Column="1"
                Background="{DynamicResource ZeBackgroundBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource ZeBorderBrush}">
            <ListBox ItemsSource="{Binding Messages}"
                     SelectedItem="{Binding SelectedMessage}"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="m:MessageViewModel">
                        <Border Padding="10,8"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{DynamicResource ZeBorderBrush}">
                            <Grid ColumnDefinitions="44,*">
                                <Border Grid.Column="0"
                                        Width="36" Height="36"
                                        CornerRadius="18"
                                        ClipToBounds="True"
                                        VerticalAlignment="Center">
                                    <Image Source="{Binding AvatarBitmap}"
                                           Width="36" Height="36"
                                           Stretch="UniformToFill"/>
                                </Border>
                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding SenderDisplay}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ZeTextPrimaryBrush}"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayDate}"
                                                   Foreground="{DynamicResource ZeTextSecondaryBrush}"
                                                   FontSize="11"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Subject}"
                                               Foreground="{DynamicResource ZeTextSecondaryBrush}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource ZeSelectedBrush}"/>
                    </Style>
                </ListBox.Styles>
            </ListBox>
        </Border>

        <!-- ── Spalte 3: Lesebereich ── -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*"
              Background="{DynamicResource ZeSurfaceBrush}">

            <Border Grid.Row="0" Padding="16,12"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource ZeBorderBrush}"
                    IsVisible="{Binding SelectedMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Grid RowDefinitions="Auto,Auto,Auto">

                    <TextBlock Grid.Row="0"
                               Text="{Binding SelectedMessage.Subject}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource ZeTextPrimaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>

                    <Grid Grid.Row="1" ColumnDefinitions="52,*,Auto" Margin="0,0,0,10">
                        <Border Grid.Column="0"
                                Width="40" Height="40"
                                CornerRadius="20"
                                ClipToBounds="True"
                                VerticalAlignment="Center">
                            <Image Source="{Binding SelectedMessage.AvatarBitmap}"
                                   Width="40" Height="40"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedMessage.SenderDisplay}"
                                       Foreground="{DynamicResource ZeAccentBrush}"
                                       FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="{Binding SelectedMessage.FromAddress}"
                                       Foreground="{DynamicResource ZeTextSecondaryBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding SelectedMessage.DisplayDate}"
                                   Foreground="{DynamicResource ZeTextSecondaryBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                        <Button Content="↩ Antworten"
                                Command="{Binding ReplyCommand}"
                                Background="{DynamicResource ZeSurfaceAltBrush}"
                                Foreground="{DynamicResource ZeAccentBrush}"
                                CornerRadius="6" Padding="10,6" FontSize="12"/>
                        <Button Content="↩↩ Allen antworten"
                                Command="{Binding ReplyAllCommand}"
                                Background="{DynamicResource ZeSurfaceAltBrush}"
                                Foreground="{DynamicResource ZeAccentBrush}"
                                CornerRadius="6" Padding="10,6" FontSize="12"/>
                        <Button Content="→ Weiterleiten"
                                Command="{Binding ForwardCommand}"
                                Background="{DynamicResource ZeSurfaceAltBrush}"
                                Foreground="{DynamicResource ZeAccentBrush}"
                                CornerRadius="6" Padding="10,6" FontSize="12"/>
                    </StackPanel>

                </Grid>
            </Border>

            <NativeWebView Grid.Row="1"
                           x:Name="MailBodyWebView"
                           IsVisible="{Binding SelectedMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
        </Grid>

    </Grid>
</UserControl>