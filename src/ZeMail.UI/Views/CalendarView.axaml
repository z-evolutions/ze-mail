<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZeMail.UI.ViewModels"
             xmlns:m="using:ZeMail.UI.Models"
             xmlns:ctrl="using:ZeMail.UI.Controls"
             x:Class="ZeMail.UI.Views.CalendarView"
             x:DataType="vm:CalendarViewModel">

	<UserControl.Resources>
		<DataTemplate x:Key="WeekEventTemplate" x:DataType="m:CalendarEventViewModel">
			<Border Background="{Binding Color}"
                    CornerRadius="3"
                    Padding="4,2"
                    Cursor="Hand"
                    Opacity="{Binding DragOpacity}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
				<StackPanel Spacing="1">
					<TextBlock Text="{Binding Title}"
                               Foreground="White" FontSize="10"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
					<TextBlock Text="{Binding TimeRange}"
                               Foreground="#c0c0ff" FontSize="9"/>
				</StackPanel>
			</Border>
		</DataTemplate>

		<DataTemplate x:Key="DayEventTemplate" x:DataType="m:CalendarEventViewModel">
			<Border Background="{Binding Color}"
                    CornerRadius="5"
                    Padding="8,4"
                    Cursor="Hand"
                    Opacity="{Binding DragOpacity}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
				<StackPanel Spacing="2">
					<TextBlock Text="{Binding Title}"
                               Foreground="White" FontSize="12"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
					<TextBlock Text="{Binding TimeRange}"
                               Foreground="#c0c0ff" FontSize="10"/>
				</StackPanel>
			</Border>
		</DataTemplate>

		<!-- Monatsansicht: nur Zellenhintergrund + Tagesnummer, Events werden separat vom CalendarMonthGrid gerendert -->
		<DataTemplate x:Key="MonthCellTemplate" x:DataType="m:CalendarDayViewModel">
			<Border Background="{Binding DayBackground}"
                    BorderThickness="0,0,1,1" BorderBrush="#2a2a4a">
				<Panel HorizontalAlignment="Right" VerticalAlignment="Top"
                       Width="24" Height="24" Margin="0,4,4,0">
					<Ellipse Fill="#3a3aff" IsVisible="{Binding IsToday}"/>
					<TextBlock Text="{Binding DayNumber}" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{Binding DayNumberColor}"/>
				</Panel>
			</Border>
		</DataTemplate>

		<!-- Monatsansicht: kompakte Event-Zeile innerhalb einer Zelle -->
		<DataTemplate x:Key="MonthEventTemplate" x:DataType="m:CalendarEventViewModel">
			<Border Background="{Binding Color}"
                    CornerRadius="3" Padding="4,1"
                    Cursor="Hand"
                    Opacity="{Binding DragOpacity}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
				<TextBlock Text="{Binding DisplayTitle}"
                           Foreground="White" FontSize="10"
                           TextTrimming="CharacterEllipsis"/>
			</Border>
		</DataTemplate>
	</UserControl.Resources>

	<Grid ColumnDefinitions="200,*,260" RowDefinitions="56,*">

		<!-- ── Topbar ── -->
		<Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0"
                Background="#12122a"
                BorderThickness="0,0,0,1" BorderBrush="#2a2a4a"
                Padding="16,0">
			<Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">
				<Button Grid.Column="0" Content="◀"
                        Command="{Binding PreviousCommand}"
                        Background="Transparent" Foreground="#c0c0ff"
                        FontSize="16" Width="36" Height="36"/>
				<TextBlock Grid.Column="1"
                           Text="{Binding CurrentPeriodLabel}"
                           Foreground="#e0e0ff" FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="4,0"/>
				<Button Grid.Column="2" Content="▶"
                        Command="{Binding NextCommand}"
                        Background="Transparent" Foreground="#c0c0ff"
                        FontSize="16" Width="36" Height="36"/>
				<Button Grid.Column="3" Content="Heute"
                        Command="{Binding GoToTodayCommand}"
                        Background="Transparent" Foreground="#7070ff"
                        FontSize="13" Margin="8,0" Padding="8,4"/>
				<StackPanel Grid.Column="5" Orientation="Horizontal"
                            Spacing="0" VerticalAlignment="Center" Margin="0,0,12,0">
					<Button Content="Monat" Command="{Binding SetMonthViewCommand}"
                            Background="#2a2a4a" Foreground="#c0c0ff"
                            CornerRadius="6,0,0,6" Padding="12,6" FontSize="12"/>
					<Button Content="Woche" Command="{Binding SetWeekViewCommand}"
                            Background="#2a2a4a" Foreground="#c0c0ff"
                            CornerRadius="0" Padding="12,6" FontSize="12"/>
					<Button Content="Tag" Command="{Binding SetDayViewCommand}"
                            Background="#2a2a4a" Foreground="#c0c0ff"
                            CornerRadius="0,6,6,0" Padding="12,6" FontSize="12"/>
				</StackPanel>
				<Button Grid.Column="6" Content="+ Neuer Termin"
                        Command="{Binding NewEventCommand}"
                        Background="#3a3aff" Foreground="White"
                        FontSize="13" FontWeight="SemiBold"
                        CornerRadius="6" Padding="12,6" VerticalAlignment="Center"/>
			</Grid>
		</Border>

		<!-- ── Linke Kalender-Sidebar ── -->
		<Border Grid.Column="0" Grid.Row="1"
                Background="#0a0a1a"
                BorderThickness="0,0,1,0" BorderBrush="#2a2a4a"
                Padding="12,16">
			<StackPanel Spacing="4">
				<TextBlock Text="KALENDER"
                           Foreground="#404070" FontSize="10" FontWeight="Bold"
                           Margin="4,0,0,8"/>
				<ItemsControl ItemsSource="{Binding Calendars}">
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="vm:CalendarSidebarItem">
							<Button Background="Transparent" BorderThickness="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Padding="4,5"
                                    Command="{Binding $parent[UserControl].DataContext.ToggleCalendarCommand}"
                                    CommandParameter="{Binding}">
								<Grid ColumnDefinitions="20,*,20">
									<Border Grid.Column="0" Width="14" Height="14"
                                            CornerRadius="3"
                                            BorderBrush="{Binding Color}"
                                            BorderThickness="1.5"
                                            Background="Transparent"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
										<Border Width="8" Height="8"
                                                CornerRadius="2"
                                                Background="{Binding Color}"
                                                IsVisible="{Binding IsVisible}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
									</Border>
									<StackPanel Grid.Column="1" Margin="6,0" VerticalAlignment="Center">
										<TextBlock Text="{Binding Name}"
                                                   Foreground="#c0c0e0" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
										<TextBlock Text="CalDAV"
                                                   Foreground="#00aaaa" FontSize="9"
                                                   IsVisible="{Binding IsCalDav}"/>
									</StackPanel>
									<Panel Grid.Column="2" Width="14" Height="14" VerticalAlignment="Center">
										<PathIcon Width="12" Height="12" Foreground="#506070"
                                                  IsVisible="{Binding IsVisible}"
                                                  Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"/>
										<PathIcon Width="12" Height="12" Foreground="#506070"
                                                  IsVisible="{Binding !IsVisible}"
                                                  Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.75 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z"/>
									</Panel>
								</Grid>
							</Button>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>
		</Border>

		<!-- ── Monatsansicht ── -->
		<Grid Grid.Column="1" Grid.Row="1" RowDefinitions="36,*"
              IsVisible="{Binding IsMonthView}">
			<ItemsControl Grid.Row="0" ItemsSource="{Binding WeekDayHeaders}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<UniformGrid Columns="7"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border BorderThickness="0,0,1,1" BorderBrush="#2a2a4a" Background="#0d0d1f">
							<TextBlock Text="{Binding}" Foreground="#7070a0"
                                       FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- CalendarMonthGrid ersetzt die bisherige ItemsControl+UniformGrid-Struktur -->
			<ctrl:CalendarMonthGrid
                Grid.Row="1"
                x:Name="MonthGrid"
                Days="{Binding Days}"
                CellTemplate="{StaticResource MonthCellTemplate}"
                EventTemplate="{StaticResource MonthEventTemplate}"/>
		</Grid>

		<!-- ── Wochenansicht ── -->
		<Grid Grid.Column="1" Grid.Row="1" RowDefinitions="64,*"
              IsVisible="{Binding IsWeekView}">
			<Grid Grid.Row="0" ColumnDefinitions="48,*">
				<Border Grid.Column="0" Background="#0d0d1f"
                        BorderThickness="0,0,1,1" BorderBrush="#2a2a4a"/>
				<ItemsControl Grid.Column="1" ItemsSource="{Binding WeekDays}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<UniformGrid Columns="7"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="m:CalendarDayViewModel">
							<Border BorderThickness="1,0,0,1" BorderBrush="#2a2a4a"
                                    Background="#0d0d1f" Padding="0,6">
								<StackPanel HorizontalAlignment="Center" Spacing="3">
									<TextBlock Text="{Binding Date, StringFormat='{}{0:ddd}'}"
                                               Foreground="#7070a0" FontSize="11" FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
									<Panel Width="28" Height="28" HorizontalAlignment="Center">
										<Ellipse Fill="#3a3aff" IsVisible="{Binding IsToday}"/>
										<TextBlock Text="{Binding DayNumber}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="#e0e0ff"/>
									</Panel>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</Grid>
			<ScrollViewer Grid.Row="1">
				<Panel Height="1440">
					<ItemsControl ItemsSource="{Binding HourLabels}" IsHitTestVisible="False">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Height="60" BorderThickness="0,0,0,1" BorderBrush="#353558"/>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
					<ItemsControl ItemsSource="{Binding HourLabels}"
                                  Width="48" HorizontalAlignment="Left" IsHitTestVisible="False">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Height="60">
									<TextBlock Text="{Binding}" Foreground="#7070a0"
                                               FontSize="11" VerticalAlignment="Top" Margin="6,2"/>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
					<ctrl:CalendarWeekGrid
                        x:Name="WeekGrid"
                        Margin="48,0,0,0"
                        WeekDays="{Binding WeekDays}"
                        EventTemplate="{StaticResource WeekEventTemplate}"
                        Height="1440"/>
					<Canvas IsHitTestVisible="False">
						<Line Canvas.Left="48" Canvas.Top="{Binding CurrentTimeOffset}"
                              StartPoint="0,0" EndPoint="2000,0"
                              Stroke="#ff4444" StrokeThickness="1.5"
                              IsVisible="{Binding ShowCurrentTimeLine}"/>
						<Ellipse Canvas.Left="40" Canvas.Top="{Binding CurrentTimeOffset}"
                                 Width="8" Height="8" Margin="0,-4,0,0" Fill="#ff4444"
                                 IsVisible="{Binding ShowCurrentTimeLine}"/>
					</Canvas>
				</Panel>
			</ScrollViewer>
		</Grid>

		<!-- ── Tagesansicht ── -->
		<Grid Grid.Column="1" Grid.Row="1" RowDefinitions="48,*"
              IsVisible="{Binding IsDayView}">
			<Border Grid.Row="0" Background="#0d0d1f"
                    BorderThickness="0,0,0,1" BorderBrush="#2a2a4a" Padding="16,0">
				<TextBlock Text="{Binding CurrentPeriodLabel}"
                           Foreground="#e0e0ff" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
			</Border>
			<ScrollViewer Grid.Row="1">
				<Panel Height="1440">
					<ItemsControl ItemsSource="{Binding HourLabels}" IsHitTestVisible="False">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Height="60" BorderThickness="0,0,0,1" BorderBrush="#353558"/>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
					<ItemsControl ItemsSource="{Binding HourLabels}"
                                  Width="48" HorizontalAlignment="Left" IsHitTestVisible="False">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Border Height="60">
									<TextBlock Text="{Binding}" Foreground="#7070a0"
                                               FontSize="11" VerticalAlignment="Top" Margin="6,2"/>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
					<Border Margin="48,0,4,0" BorderThickness="1,0,0,0" BorderBrush="#353558"
                            ClipToBounds="True">
						<ctrl:CalendarDayPanel
                            x:Name="DayPanel"
                            Events="{Binding SelectedDayEvents}"
                            EventTemplate="{StaticResource DayEventTemplate}"
                            ColumnDate="{Binding CurrentDay}"
                            ColumnIndex="0"
                            Height="1440"/>
					</Border>
					<Canvas IsHitTestVisible="False">
						<Line Canvas.Left="48" Canvas.Top="{Binding CurrentTimeOffset}"
                              StartPoint="0,0" EndPoint="2000,0"
                              Stroke="#ff4444" StrokeThickness="1.5"
                              IsVisible="{Binding ShowCurrentTimeLine}"/>
						<Ellipse Canvas.Left="40" Canvas.Top="{Binding CurrentTimeOffset}"
                                 Width="8" Height="8" Margin="0,-4,0,0" Fill="#ff4444"
                                 IsVisible="{Binding ShowCurrentTimeLine}"/>
					</Canvas>
				</Panel>
			</ScrollViewer>
		</Grid>

		<!-- ── Rechte Tages-Sidebar ── -->
		<Border Grid.Column="2" Grid.Row="1"
                Background="#0a0a1a" BorderThickness="1,0,0,0" BorderBrush="#2a2a4a" Padding="16">
			<StackPanel Spacing="12">
				<TextBlock Text="{Binding SelectedDay.Date, StringFormat='{}{0:dddd, dd. MMMM}'}"
                           Foreground="#c0c0ff" FontSize="14" FontWeight="SemiBold"/>
				<TextBlock Text="Keine Termine" Foreground="#5050a0" FontSize="12"
                           IsVisible="{Binding !SelectedDayEvents.Count}"/>
				<ItemsControl ItemsSource="{Binding SelectedDayEvents}">
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="m:CalendarEventViewModel">
							<Button Background="#12122a" BorderThickness="3,0,0,0"
                                    BorderBrush="{Binding Color}" CornerRadius="8"
                                    Padding="12,8" Margin="0,0,0,8"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding $parent[UserControl].DataContext.EditEventCommand}"
                                    CommandParameter="{Binding}">
								<StackPanel Spacing="4">
									<TextBlock Text="{Binding Title}"
                                               Foreground="#e0e0ff" FontSize="13" FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
									<TextBlock Text="{Binding TimeRange}"
                                               Foreground="#7070ff" FontSize="11"/>
									<TextBlock Text="{Binding Location}"
                                               Foreground="#6060a0" FontSize="11"
                                               IsVisible="{Binding Location,
                                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
								</StackPanel>
							</Button>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>
		</Border>

	</Grid>
</UserControl>