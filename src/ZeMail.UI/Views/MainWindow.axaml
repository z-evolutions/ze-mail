<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZeMail.UI.ViewModels"
        x:Class="ZeMail.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/zemail.ico"
        Title="ZE-Mail"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        Background="#1a1a2e">

    <Grid RowDefinitions="48,*">

        <!-- ── Topbar ── -->
        <Border Grid.Row="0" Background="#0a0a18"
                BorderThickness="0,0,0,1" BorderBrush="#2a2a4a">
            <Grid ColumnDefinitions="64,Auto,*,Auto,Auto" Margin="0,0,12,0">

                <TextBlock Grid.Column="0"
                           Text="ZE-Mail"
                           Foreground="#7070ff"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedNavItem.Label}"
                           Foreground="#c0c0ff"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>

                <Border Grid.Column="2"
                        Background="#1a1a3a"
                        CornerRadius="6"
                        Margin="24,8"
                        Padding="10,0">
                    <Grid ColumnDefinitions="Auto,*">
                        <PathIcon Grid.Column="0"
                                  Width="12" Height="12"
                                  Foreground="#6060a0"
                                  Margin="0,0,6,0"
                                  VerticalAlignment="Center"
                                  Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText}"
                                 PlaceholderText="Suchen…"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#c0c0e0"
                                 VerticalAlignment="Center"
                                 FontSize="13"/>
                    </Grid>
                </Border>

                <!-- Sync-Button -->
                <Button Grid.Column="3"
                        Command="{Binding SyncCommand}"
                        Background="Transparent"
                        Width="40" Height="40"
                        HorizontalContentAlignment="Center"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Synchronisieren">
                    <PathIcon Width="18" Height="18" Foreground="#6060a0"
                              Data="M12,18A6,6 0 0,1 6,12C6,11 6.25,10.03 6.7,9.2L5.24,7.74C4.46,8.97 4,10.43 4,12A8,8 0 0,0 12,20V23L16,19L12,15V18M12,4V1L8,5L12,9V6A6,6 0 0,1 18,12C18,13 17.75,13.97 17.3,14.8L18.76,16.26C19.54,15.03 20,13.57 20,12A8,8 0 0,0 12,4Z"/>
                </Button>

                <!-- Neue Mail Button -->
                <Button Grid.Column="4"
                        Command="{Binding NewMailCommand}"
                        Background="#3a3aff"
                        Foreground="White"
                        FontSize="13"
                        FontWeight="SemiBold"
                        CornerRadius="6"
                        Padding="12,6"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        ToolTip.Tip="Neue Mail">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Width="14" Height="14" Foreground="White"
                                  Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z"/>
                        <TextBlock Text="Neu" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </Grid>
        </Border>

        <!-- ── Hauptbereich ── -->
        <Grid Grid.Row="1" ColumnDefinitions="64,*">

            <Border Grid.Column="0" Background="#0f0f1a"
                    BorderThickness="0,0,1,0" BorderBrush="#2a2a4a">
                <DockPanel>
                    <!-- Einstellungen -->
                    <Button DockPanel.Dock="Bottom"
                            Command="{Binding OpenSettingsCommand}"
                            Background="Transparent"
                            Width="64" Height="56"
                            HorizontalContentAlignment="Center"
                            ToolTip.Tip="Einstellungen">
                        <PathIcon Width="20" Height="20" Foreground="#6060a0"
                                  Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
                    </Button>

                    <!-- Navigation -->
                    <ItemsControl ItemsSource="{Binding NavItems}" Margin="0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:NavItem">
                                <Button Command="{Binding $parent[Window].DataContext.NavigateCommand}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent"
                                        Width="64" Height="56"
                                        ToolTip.Tip="{Binding Label}">
                                    <PathIcon Width="22" Height="22"
                                              Foreground="#6060a0"
                                              Data="{Binding PathData}"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentView}"/>

        </Grid>

    </Grid>
</Window>