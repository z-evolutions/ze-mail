<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZeMail.UI.ViewModels"
             x:Class="ZeMail.UI.Views.ContactsView"
             x:DataType="vm:ContactsViewModel">

    <Grid ColumnDefinitions="200,240,*">

        <!-- ── Spalte 1: Gruppen ── -->
        <Border Grid.Column="0" Background="#07071a"
                BorderThickness="0,0,1,0" BorderBrush="#2a2a4a">
            <DockPanel>

                <Border DockPanel.Dock="Top" Padding="10,10"
                        BorderThickness="0,0,0,1" BorderBrush="#2a2a4a">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="GRUPPEN"
                                   Foreground="#5050a0" FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="+"
                                Command="{Binding NewGroupCommand}"
                                Background="Transparent" Foreground="#7070ff"
                                FontSize="18" Width="28" Height="28"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Padding="0"/>
                    </Grid>
                </Border>

                <Border DockPanel.Dock="Top" Padding="10,8"
                        BorderThickness="0,0,0,1" BorderBrush="#2a2a4a"
                        IsVisible="{Binding IsGroupEditMode}">
                    <StackPanel Spacing="6">
                        <TextBox Text="{Binding EditGroupName}"
                                 PlaceholderText="Gruppenname"
                                 CornerRadius="4" Padding="6,4" FontSize="12"/>
                        <TextBox Text="{Binding EditGroupIcon}"
                                 PlaceholderText="Emoji (z.B. 👥)"
                                 CornerRadius="4" Padding="6,4" FontSize="12"/>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Button Content="✓"
                                    Command="{Binding SaveGroupCommand}"
                                    Background="#3a3aff" Foreground="White"
                                    CornerRadius="4" Padding="8,4" FontSize="12"/>
                            <Button Content="✕"
                                    Command="{Binding CancelGroupEditCommand}"
                                    Background="Transparent" Foreground="#6060a0"
                                    CornerRadius="4" Padding="8,4" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <ListBox ItemsSource="{Binding Groups}"
                         SelectedItem="{Binding SelectedGroup}"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ContactGroupViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,4">
                                <TextBlock Text="{Binding Icon}" FontSize="14"/>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#c0c0e0" FontSize="13"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#1e1e4a"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            Spacing="4" Margin="8,6"
                            IsVisible="{Binding SelectedGroup.Id,
                                Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Button Content="✏"
                            Command="{Binding EditGroupCommand}"
                            Background="Transparent" Foreground="#6060a0"
                            Padding="6,4" FontSize="13"
                            ToolTip.Tip="Gruppe bearbeiten"/>
                    <Button Content="🗑"
                            Command="{Binding DeleteGroupCommand}"
                            Background="Transparent" Foreground="#804040"
                            Padding="6,4" FontSize="13"
                            ToolTip.Tip="Gruppe löschen"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ── Spalte 2: Kontaktliste ── -->
        <Border Grid.Column="1" Background="#0a0a1a"
                BorderThickness="0,0,1,0" BorderBrush="#2a2a4a">
            <DockPanel>

                <Border DockPanel.Dock="Top" Padding="10,10"
                        BorderThickness="0,0,0,1" BorderBrush="#2a2a4a">
                    <Grid ColumnDefinitions="*,Auto">
                        <Border Grid.Column="0" Background="#1a1a3a"
                                CornerRadius="6" Padding="8,4">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="🔍"
                                           Foreground="#6060a0" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding SearchText}"
                                         PlaceholderText="Suchen…"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#c0c0e0" FontSize="12"/>
                            </Grid>
                        </Border>
                        <Button Grid.Column="1" Content="+ Neu"
                                Command="{Binding NewContactCommand}"
                                Background="#3a3aff" Foreground="White"
                                CornerRadius="6" Padding="8,4"
                                Margin="6,0,0,0" FontSize="11"/>
                    </Grid>
                </Border>

                <ListBox ItemsSource="{Binding FilteredContacts}"
                         SelectedItem="{Binding SelectedContact}"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ContactItemViewModel">
                            <Grid ColumnDefinitions="40,*" Margin="8,4">
                                <Panel Grid.Column="0" Width="32" Height="32">
                                    <!-- Initialen -->
                                    <Ellipse Width="32" Height="32"
                                             IsVisible="{Binding !HasAvatar}">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="#3a3aff"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="{Binding Initials}"
                                               Foreground="White" FontSize="12" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               IsVisible="{Binding !HasAvatar}"/>
                                    <!-- Gravatar -->
                                    <Ellipse Width="32" Height="32"
                                             IsVisible="{Binding HasAvatar}">
                                        <Ellipse.Fill>
                                            <ImageBrush Source="{Binding AvatarBitmap}"
                                                        Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Panel>

                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="#e0e0ff" FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding PrimaryEmail}"
                                               Foreground="#6060a0" FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#1e1e4a"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ── Spalte 3: Detail / Bearbeiten ── -->
        <ScrollViewer Grid.Column="2" Padding="28,24">
            <StackPanel Spacing="0" IsVisible="{Binding HasSelection}">

                <!-- ── PROFILANSICHT ── -->
                <StackPanel IsVisible="{Binding !IsEditMode}" Spacing="0">

                    <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,24">
                        <Panel Width="80" Height="80">
                            <!-- Initialen-Fallback -->
                            <Ellipse Width="80" Height="80"
                                     IsVisible="{Binding !SelectedContact.HasAvatar}">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Color="#5a5aff" Offset="0"/>
                                        <GradientStop Color="#3a3aaa" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding SelectedContact.Initials}"
                                       Foreground="White" FontSize="28" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsVisible="{Binding !SelectedContact.HasAvatar}"/>
                            <!-- Gravatar -->
                            <Ellipse Width="80" Height="80"
                                     IsVisible="{Binding SelectedContact.HasAvatar}">
                                <Ellipse.Fill>
                                    <ImageBrush Source="{Binding SelectedContact.AvatarBitmap}"
                                                Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Panel>

                        <StackPanel VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="{Binding SelectedContact.DisplayName}"
                                       Foreground="#e0e0ff" FontSize="22" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedContact.Organization}"
                                       Foreground="#8080c0" FontSize="14"
                                       IsVisible="{Binding SelectedContact.Organization,
                                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <TextBlock Text="{Binding SelectedContact.Department}"
                                       Foreground="#6060a0" FontSize="12"
                                       IsVisible="{Binding SelectedContact.Department,
                                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Background="#12122a" CornerRadius="10" Padding="20" Margin="0,0,0,12">
                        <StackPanel Spacing="14">

                            <StackPanel Spacing="4"
                                        IsVisible="{Binding SelectedContact.PrimaryEmail,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="E-MAIL" Foreground="#5050a0"
                                           FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedContact.PrimaryEmail}"
                                           Foreground="#7070ff" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Spacing="4"
                                        IsVisible="{Binding SelectedContact.PrimaryPhone,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="TELEFON" Foreground="#5050a0"
                                           FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedContact.PrimaryPhone}"
                                           Foreground="#c0c0e0" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Spacing="4"
                                        IsVisible="{Binding SelectedContact.Website,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="WEBSITE" Foreground="#5050a0"
                                           FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="WebsiteText"
                                           Text="{Binding SelectedContact.Website}"
                                           Foreground="#7070ff" FontSize="14"
                                           TextDecorations="Underline"
                                           Cursor="Hand"/>
                            </StackPanel>

                            <StackPanel Spacing="4"
                                        IsVisible="{Binding SelectedContact.Street,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="ADRESSE" Foreground="#5050a0"
                                           FontSize="10" FontWeight="Bold"/>
                                <TextBlock Foreground="#c0c0e0" FontSize="14">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}&#10;{1} {2}&#10;{3}">
                                            <Binding Path="SelectedContact.Street"/>
                                            <Binding Path="SelectedContact.PostalCode"/>
                                            <Binding Path="SelectedContact.City"/>
                                            <Binding Path="SelectedContact.Country"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <Border Background="#12122a" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                            IsVisible="{Binding SelectedContact.Notes,
                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="NOTIZEN" Foreground="#5050a0"
                                       FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedContact.Notes}"
                                       Foreground="#c0c0e0" FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="✉ Mail schreiben"
                                Command="{Binding WriteMailCommand}"
                                Background="#1a1a4a" Foreground="#c0c0ff"
                                CornerRadius="6" Padding="14,8"
                                IsVisible="{Binding SelectedContact.PrimaryEmail,
                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        <Button Content="✏ Bearbeiten"
                                Command="{Binding EditCommand}"
                                Background="#2a2a5a" Foreground="#c0c0ff"
                                CornerRadius="6" Padding="14,8"/>
                        <Button Content="🗑 Löschen"
                                Command="{Binding DeleteCommand}"
                                Background="#4a1a1a" Foreground="#ff6060"
                                CornerRadius="6" Padding="14,8"/>
                    </StackPanel>

                </StackPanel>

                <!-- ── BEARBEITUNGSANSICHT ── -->
                <StackPanel IsVisible="{Binding IsEditMode}" Spacing="14">

                    <TextBlock Foreground="#7070ff" FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,8" IsVisible="{Binding IsNewContact}"
                               Text="Neuer Kontakt"/>
                    <TextBlock Foreground="#7070ff" FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,8" IsVisible="{Binding !IsNewContact}"
                               Text="Kontakt bearbeiten"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Name *" Foreground="#8080a0" FontSize="12"/>
                        <TextBox Text="{Binding EditDisplayName}"
                                 PlaceholderText="Vor- und Nachname"
                                 CornerRadius="6" Padding="10,6"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Organisation" Foreground="#8080a0" FontSize="12"/>
                            <TextBox Text="{Binding EditOrganization}"
                                     PlaceholderText="optional"
                                     CornerRadius="6" Padding="10,6"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Abteilung" Foreground="#8080a0" FontSize="12"/>
                            <TextBox Text="{Binding EditDepartment}"
                                     PlaceholderText="optional"
                                     CornerRadius="6" Padding="10,6"/>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="E-Mail" Foreground="#8080a0" FontSize="12"/>
                            <TextBox Text="{Binding EditEmail}"
                                     PlaceholderText="mehrere mit Komma"
                                     CornerRadius="6" Padding="10,6"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Telefon" Foreground="#8080a0" FontSize="12"/>
                            <TextBox Text="{Binding EditPhone}"
                                     PlaceholderText="mehrere mit Komma"
                                     CornerRadius="6" Padding="10,6"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Website" Foreground="#8080a0" FontSize="12"/>
                        <TextBox Text="{Binding EditWebsite}"
                                 PlaceholderText="https://"
                                 CornerRadius="6" Padding="10,6"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Straße" Foreground="#8080a0" FontSize="12"/>
                        <TextBox Text="{Binding EditStreet}"
                                 PlaceholderText="Straße und Hausnummer"
                                 CornerRadius="6" Padding="10,6"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="120,16,*,16,*">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="PLZ" Foreground="#8080a0" FontSize="12"/>
                            <TextBox Text="{Binding EditPostalCode}"
                                     CornerRadius="6" Padding="10,6"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Stadt" Foreground="#8080a0" FontSize="12"/>
                            <TextBox Text="{Binding EditCity}"
                                     CornerRadius="6" Padding="10,6"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Spacing="4">
                            <TextBlock Text="Land" Foreground="#8080a0" FontSize="12"/>
                            <TextBox Text="{Binding EditCountry}"
                                     CornerRadius="6" Padding="10,6"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Notizen" Foreground="#8080a0" FontSize="12"/>
                        <TextBox Text="{Binding EditNotes}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="80" CornerRadius="6" Padding="10,6"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,4,0,0">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding StatusMessage}"
                                   Foreground="#a0a0ff" FontSize="12"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Abbrechen"
                                Command="{Binding CancelEditCommand}"
                                Background="Transparent" Foreground="#6060a0"
                                Padding="12,8" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="Speichern ✓"
                                Command="{Binding SaveCommand}"
                                Background="#3a3aff" Foreground="White"
                                FontWeight="SemiBold" CornerRadius="6"
                                Padding="16,8"/>
                    </Grid>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>