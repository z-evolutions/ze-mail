<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZeMail.UI.ViewModels"
        x:Class="ZeMail.UI.Views.ComposeWindow"
        x:DataType="vm:ComposeViewModel"
        Title="Neue Mail"
        Icon="/Assets/zemail.ico"
        Width="760" Height="640"
        MinWidth="560" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ZeBackgroundBrush}">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" Margin="16">

        <!-- Von -->
        <Grid Grid.Row="0" ColumnDefinitions="70,*" Margin="0,0,0,6">
            <TextBlock Grid.Column="0" Text="Von:"
                       Foreground="{DynamicResource ZeTextSecondaryBrush}"
                       FontSize="13" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Accounts}"
                      SelectedItem="{Binding SelectedAccount}"
                      HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:AccountItemViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource ZeTextPrimaryBrush}"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding EmailAddress}"
                                       Foreground="{DynamicResource ZeTextSecondaryBrush}"
                                       FontSize="12"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <!-- An -->
        <Grid Grid.Row="1" ColumnDefinitions="70,*" Margin="0,0,0,6">
            <TextBlock Grid.Column="0" Text="An:"
                       Foreground="{DynamicResource ZeTextSecondaryBrush}"
                       FontSize="13" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     Text="{Binding To}"
                     PlaceholderText="empfaenger@example.com"
                     CornerRadius="6" Padding="10,6"/>
        </Grid>

        <!-- CC -->
        <Grid Grid.Row="2" ColumnDefinitions="70,*" Margin="0,0,0,6">
            <TextBlock Grid.Column="0" Text="CC:"
                       Foreground="{DynamicResource ZeTextSecondaryBrush}"
                       FontSize="13" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Cc}"
                     PlaceholderText="optional"
                     CornerRadius="6" Padding="10,6"/>
        </Grid>

        <!-- Betreff -->
        <Grid Grid.Row="3" ColumnDefinitions="70,*" Margin="0,0,0,10">
            <TextBlock Grid.Column="0" Text="Betreff:"
                       Foreground="{DynamicResource ZeTextSecondaryBrush}"
                       FontSize="13" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Subject}"
                     PlaceholderText="Betreff"
                     CornerRadius="6" Padding="10,6"/>
        </Grid>

        <!-- Body: NativeWebView als HTML-Editor -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource ZeBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Margin="0,0,0,10"
                ClipToBounds="True">
            <NativeWebView x:Name="ComposeBodyWebView"/>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="5" ColumnDefinitions="*,Auto,Auto">
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource ZeAccentBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="Abbrechen"
                    Command="{Binding CancelCommand}"
                    Background="Transparent"
                    Foreground="{DynamicResource ZeTextSecondaryBrush}"
                    Padding="12,8"
                    Margin="0,0,8,0"/>
            <Button Grid.Column="2"
                    Content="Senden ✉"
                    Command="{Binding SendCommand}"
                    IsEnabled="{Binding IsSending, Converter={x:Static BoolConverters.Not}}"
                    Background="{DynamicResource ZeAccentBrush}"
                    Foreground="{DynamicResource ZeBackgroundBrush}"
                    FontWeight="SemiBold"
                    CornerRadius="6"
                    Padding="16,8"/>
        </Grid>

    </Grid>
</Window>