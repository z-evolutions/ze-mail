<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZeMail.UI.ViewModels"
        xmlns:views="using:ZeMail.UI.Views"
        x:Class="ZeMail.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ZE-Mail"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        Background="#1a1a2e">

    <Grid ColumnDefinitions="64,*">

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0f0f1a" Padding="0,16">
            <ItemsControl ItemsSource="{Binding NavItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:NavItem">
                        <Button Command="{Binding $parent[Window].DataContext.NavigateCommand}"
                                CommandParameter="{Binding}"
                                Background="Transparent"
                                Width="64" Height="64"
                                ToolTip.Tip="{Binding Label}">
                            <TextBlock Text="{Binding Icon}"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Hauptbereich -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"/>

    </Grid>
</Window>