<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZeMail.UI.ViewModels"
             xmlns:m="using:ZeMail.UI.Models"
             x:Class="ZeMail.UI.Views.MailboxView"
             x:DataType="vm:MailboxViewModel">

    <Grid ColumnDefinitions="220,320,*">

        <!-- ── Spalte 1: Ordnerbaum ── -->
        <Border Grid.Column="0" Background="#12122a"
                BorderThickness="0,0,1,0" BorderBrush="#2a2a4a">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="ORDNER"
                           Foreground="#6060a0"
                           FontSize="11"
                           FontWeight="Bold"
                           Margin="12,16,12,8"/>
                <ListBox ItemsSource="{Binding Folders}"
                         SelectedItem="{Binding SelectedFolder}"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:FolderViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,2">
                                <TextBlock Text="{Binding Icon}" FontSize="14"/>
                                <TextBlock Text="{Binding Name}" Foreground="#c0c0e0" FontSize="13"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#1e1e4a"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ── Spalte 2: Nachrichtenliste ── -->
        <Border Grid.Column="1" Background="#0f0f23"
                BorderThickness="0,0,1,0" BorderBrush="#2a2a4a">
            <ListBox ItemsSource="{Binding Messages}"
                     SelectedItem="{Binding SelectedMessage}"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="m:MessageViewModel">
                        <Border Padding="10,8" BorderThickness="0,0,0,1" BorderBrush="#1a1a3a">
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding SenderDisplay}"
                                           FontWeight="SemiBold"
                                           Foreground="#e0e0ff"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding DisplayDate}"
                                           Foreground="#6060a0"
                                           FontSize="11"
                                           Margin="8,0,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding Subject}"
                                           Foreground="#a0a0c0"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#1e1e4a"/>
                    </Style>
                </ListBox.Styles>
            </ListBox>
        </Border>

        <!-- ── Spalte 3: Lesebereich ── -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*" Background="#0a0a1a">

            <!-- Header -->
            <Border Grid.Row="0" Padding="24,16"
                    BorderThickness="0,0,0,1" BorderBrush="#1a1a3a">
                <StackPanel IsVisible="{Binding SelectedMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="{Binding SelectedMessage.Subject}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#e0e0ff" TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{Binding SelectedMessage.SenderDisplay}"
                                       Foreground="#c0c0ff" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="{Binding SelectedMessage.FromAddress}"
                                       Foreground="#6060a0" FontSize="11"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedMessage.DisplayDate}"
                                   Foreground="#6060a0" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- NativeWebView Body -->
            <NativeWebView Grid.Row="1"
                           x:Name="MailBodyWebView"
                           IsVisible="{Binding SelectedMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
        </Grid>

    </Grid>
</UserControl>