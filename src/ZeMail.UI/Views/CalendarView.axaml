<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZeMail.UI.ViewModels"
             xmlns:m="using:ZeMail.UI.Models"
             x:Class="ZeMail.UI.Views.CalendarView"
             x:DataType="vm:CalendarViewModel">

    <Grid ColumnDefinitions="*,260" RowDefinitions="56,*">

        <!-- ── Topbar ── -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
                Background="#12122a"
                BorderThickness="0,0,0,1" BorderBrush="#2a2a4a"
                Padding="16,0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">

                <!-- Navigation -->
                <Button Grid.Column="0" Content="◀"
                        Command="{Binding PreviousCommand}"
                        Background="Transparent" Foreground="#c0c0ff"
                        FontSize="16" Width="36" Height="36"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentPeriodLabel}"
                           Foreground="#e0e0ff"
                           FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="4,0"/>

                <Button Grid.Column="2" Content="▶"
                        Command="{Binding NextCommand}"
                        Background="Transparent" Foreground="#c0c0ff"
                        FontSize="16" Width="36" Height="36"/>

                <Button Grid.Column="3" Content="Heute"
                        Command="{Binding GoToTodayCommand}"
                        Background="Transparent" Foreground="#7070ff"
                        FontSize="13" Margin="8,0" Padding="8,4"/>

                <!-- Ansichts-Toggle -->
                <StackPanel Grid.Column="5" Orientation="Horizontal"
                            Spacing="4" VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <Button Content="Monat"
                            Command="{Binding SetMonthViewCommand}"
                            Background="#2a2a4a"
                            Foreground="#c0c0ff"
                            CornerRadius="6,0,0,6"
                            Padding="10,6" FontSize="12"/>
                    <Button Content="Woche"
                            Command="{Binding SetWeekViewCommand}"
                            Background="#2a2a4a"
                            Foreground="#c0c0ff"
                            CornerRadius="0"
                            Padding="10,6" FontSize="12"/>
                    <Button Content="Tag"
                            Command="{Binding SetDayViewCommand}"
                            Background="#2a2a4a"
                            Foreground="#c0c0ff"
                            CornerRadius="0,6,6,0"
                            Padding="10,6" FontSize="12"/>
                </StackPanel>

                <!-- Neuer Termin -->
                <Button Grid.Column="6" Content="+ Neuer Termin"
                        Command="{Binding NewEventCommand}"
                        Background="#3a3aff" Foreground="White"
                        FontSize="13" FontWeight="SemiBold"
                        CornerRadius="6" Padding="12,6"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Monatsansicht ── -->
        <Grid Grid.Column="0" Grid.Row="1" RowDefinitions="32,*"
              IsVisible="{Binding IsMonthView}">

            <ItemsControl Grid.Row="0" ItemsSource="{Binding WeekDayHeaders}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="0,0,1,1" BorderBrush="#1a1a3a"
                                Background="#0f0f20">
                            <TextBlock Text="{Binding}"
                                       Foreground="#6060a0"
                                       FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Days}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="m:CalendarDayViewModel">
                        <Border BorderThickness="0,0,1,1"
                                BorderBrush="#1a1a3a"
                                Cursor="Hand">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding IsCurrentMonth,
                                    Converter={x:Static BoolConverters.Not},
                                    ConverterParameter='#080814'}"/>
                            </Border.Background>
                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Padding="0"
                                    Command="{Binding $parent[UserControl].DataContext.SelectDayCommand}"
                                    CommandParameter="{Binding}">
                                <Grid RowDefinitions="26,*">
                                    <Panel Grid.Row="0" HorizontalAlignment="Right"
                                           Margin="4,4,4,0" Width="24" Height="24">
                                        <Ellipse Fill="#3a3aff" IsVisible="{Binding IsToday}"/>
                                        <TextBlock Text="{Binding DayNumber}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding IsCurrentMonth,
                                                    Converter={x:Static BoolConverters.Not},
                                                    ConverterParameter='#404060'}"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Panel>
                                    <ItemsControl Grid.Row="1"
                                                  ItemsSource="{Binding Events}"
                                                  Margin="2,0,2,2">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="m:CalendarEventViewModel">
                                                <Border Background="#3a3aff"
                                                        CornerRadius="3"
                                                        Padding="4,1" Margin="0,1">
                                                    <TextBlock Text="{Binding DisplayTitle}"
                                                               Foreground="White"
                                                               FontSize="10"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Button>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- ── Wochenansicht ── -->
        <Grid Grid.Column="0" Grid.Row="1" RowDefinitions="32,*"
              IsVisible="{Binding IsWeekView}">

            <ItemsControl Grid.Row="0" ItemsSource="{Binding WeekDays}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="m:CalendarDayViewModel">
                        <Border BorderThickness="0,0,1,1" BorderBrush="#1a1a3a"
                                Background="#0f0f20">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{Binding Date, StringFormat='{}{0:ddd}'}"
                                           Foreground="#6060a0"
                                           FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <Panel Width="28" Height="28">
                                    <Ellipse Fill="#3a3aff" IsVisible="{Binding IsToday}"/>
                                    <TextBlock Text="{Binding DayNumber}"
                                               FontSize="14" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#e0e0ff"/>
                                </Panel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ScrollViewer Grid.Row="1">
                <Grid>
                    <!-- Stundenlabels links -->
                    <ItemsControl ItemsSource="{Binding HourLabels}"
                                  Width="48" HorizontalAlignment="Left">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Height="60" BorderThickness="0,0,0,1"
                                        BorderBrush="#1a1a3a">
                                    <TextBlock Text="{Binding}"
                                               Foreground="#4040a0"
                                               FontSize="10"
                                               VerticalAlignment="Top"
                                               Margin="4,2"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 7 Tagesspalten -->
                    <ItemsControl ItemsSource="{Binding WeekDays}"
                                  Margin="48,0,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:CalendarDayViewModel">
                                <Border BorderThickness="1,0,0,0" BorderBrush="#1a1a3a">
                                    <ItemsControl ItemsSource="{Binding Events}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="m:CalendarEventViewModel">
                                                <Border Background="#3a3aff"
                                                        CornerRadius="4"
                                                        Margin="2,1"
                                                        Padding="6,3">
                                                    <TextBlock Text="{Binding DisplayTitle}"
                                                               Foreground="White"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ── Tagesansicht ── -->
        <Grid Grid.Column="0" Grid.Row="1" RowDefinitions="48,*"
              IsVisible="{Binding IsDayView}">

            <Border Grid.Row="0" Background="#0f0f20"
                    BorderThickness="0,0,0,1" BorderBrush="#1a1a3a"
                    Padding="16,0">
                <TextBlock Text="{Binding CurrentDay, StringFormat='{}{0:dddd, dd. MMMM yyyy}'}"
                           Foreground="#e0e0ff"
                           FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Border>

            <ScrollViewer Grid.Row="1">
                <Grid>
                    <ItemsControl ItemsSource="{Binding HourLabels}"
                                  Width="48" HorizontalAlignment="Left">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Height="60" BorderThickness="0,0,0,1"
                                        BorderBrush="#1a1a3a">
                                    <TextBlock Text="{Binding}"
                                               Foreground="#4040a0"
                                               FontSize="10"
                                               VerticalAlignment="Top"
                                               Margin="4,2"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Margin="48,0,0,0"
                            BorderThickness="1,0,0,0" BorderBrush="#1a1a3a">
                        <ItemsControl ItemsSource="{Binding SelectedDayEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:CalendarEventViewModel">
                                    <Border Background="#3a3aff"
                                            CornerRadius="6"
                                            Margin="8,2"
                                            Padding="10,6">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="White"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding StartTime}"
                                                       Foreground="#c0c0ff"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ── Rechte Seitenleiste ── -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="#0a0a1a"
                BorderThickness="1,0,0,0" BorderBrush="#2a2a4a"
                Padding="16">
            <StackPanel Spacing="12">
                <TextBlock Text="{Binding SelectedDay.Date, StringFormat='{}{0:dddd, dd. MMMM}'}"
                           Foreground="#c0c0ff"
                           FontSize="14" FontWeight="SemiBold"/>

                <TextBlock Text="Keine Termine"
                           Foreground="#4040a0" FontSize="12"
                           IsVisible="{Binding !SelectedDayEvents.Count}"/>

                <ItemsControl ItemsSource="{Binding SelectedDayEvents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="m:CalendarEventViewModel">
                            <Border Background="#12122a" CornerRadius="8"
                                    Padding="12,8" Margin="0,0,0,8"
                                    BorderThickness="3,0,0,0" BorderBrush="#5AC8FA">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="#e0e0ff"
                                               FontSize="13" FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding StartTime}"
                                               Foreground="#7070ff" FontSize="11"/>
                                    <TextBlock Text="{Binding Location}"
                                               Foreground="#6060a0" FontSize="11"
                                               IsVisible="{Binding Location,
                                                   Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>